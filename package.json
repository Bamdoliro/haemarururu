{
  "name": "maruruuu",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "configs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=./apps/**",
    "lint": "turbo run lint",
    "type-check": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "eslint": "^7.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^2.8.8",
    "turbo": "^2.3.3",
    "typescript": "^5.1.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.1",
      "@types/react-dom": "18.3.0"
    }
  },
  "packageManager": "pnpm@9.0.0"
}
